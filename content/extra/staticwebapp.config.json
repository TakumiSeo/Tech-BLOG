{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/images/*",
      "/theme/*",
      "/feeds/*",
      "*.html"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
    "Content-Security-Policy": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://technotesewo.blob.core.windows.net data:; script-src 'self' 'unsafe-inline'; font-src 'self'"
  },
  "routes": [
    {
      "route": "/drafts/*",
      "statusCode": 404
    }
  ]
}
