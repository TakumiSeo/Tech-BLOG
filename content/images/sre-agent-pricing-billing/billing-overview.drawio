<mxfile host="app.diagrams.net" agent="copilot">
  <diagram id="billing" name="SRE Agent Billing">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Azure SRE Agent 課金モデル (AAU = Azure Agent Unit / 1 AAU = $0.10)" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="2320" height="40" as="geometry"/>
        </mxCell>

        <!-- Agent (center) -->
        <mxCell id="agent" value="SRE Agent (1 つ)" style="shape=mxgraph.azure.virtual_machine;html=1;labelPosition=right;align=left;verticalLabelPosition=middle;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="120" width="60" height="60" as="geometry"/>
        </mxCell>

        <!-- ============ Always-on flow (LEFT) ============ -->
        <mxCell id="alwaysOn" value="① Always-on フロー (固定コスト)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FA;strokeColor=#0078D4;dashed=0;verticalAlign=top;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="80" y="240" width="700" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="aoRate" value="エージェント存在時間 × 4 AAU / hour ($0.40 / hour)&#xa;(エージェント作成 → 削除 まで継続)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="100" y="290" width="660" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="aoHour" value="1 時間&#xa;= 4 AAU&#xa;= $0.40" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0078D4;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="120" y="370" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="aoDay" value="1 日 (24h)&#xa;= 96 AAU&#xa;= $9.60" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0078D4;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="320" y="370" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="aoMonth" value="30 日換算&#xa;= 2,880 AAU&#xa;= $288.00" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0078D4;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="520" y="370" width="180" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="aoNote" value="※ エージェントを「停止」しても Always-on 課金は継続&#xa;※ 完全に止めるには「削除」が必要" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="120" y="470" width="600" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="aoFormula" value="月額 (固定) = 4 × (エージェント稼働時間 [h]) AAU = $0.40 × 稼働時間 [h]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CE;strokeColor=#D9B300;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="540" width="580" height="50" as="geometry"/>
        </mxCell>

        <!-- ============ Active flow (RIGHT) ============ -->
        <mxCell id="active" value="② Active フロー (変動コスト・トークンベース)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEA;strokeColor=#DD344C;dashed=0;verticalAlign=top;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="820" y="240" width="1540" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="actDesc" value="エージェントが「処理に費やした時間」のみ課金&#xa;(ユーザー応答待ち・承認待ちは課金対象外。月初にカウンタリセット / 1 AAU = $0.10)" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="840" y="280" width="1500" height="40" as="geometry"/>
        </mxCell>

        <!-- 4 token types -->
        <mxCell id="tIn" value="Input&#xa;(プロンプト・&#xa;ツール結果・&#xa;コンテキスト)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;fontSize=12;" vertex="1" parent="1">
