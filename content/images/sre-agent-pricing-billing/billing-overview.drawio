        <mxCell id="actFormula" value="トークン種別ごとに  AAU = (使用トークン数 / 1,000,000) × レート  を算出し、4 種別を合算 → ×$0.10 で USD に換算" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CE;strokeColor=#D9B300;fontSize=14;fontStyle=1;" vertex="1" parent="1">
