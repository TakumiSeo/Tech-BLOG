<mxfile host="65bd71144e">
    <diagram id="weekly-report-4agents" name="Weekly Report - 4 Agent Chain">
        <mxGraphModel dx="429" dy="616" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="週次レポート — 4 Custom Agent 構成（責務分離版）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="2720" height="36" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="A: 収集/判定 → B: 原因探索 → C: レポート整形(PDF) → D: 配信。書込みは D のみ、他は読取専用。" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=2;fontColor=#555555;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="2720" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="trg-box" value="① Triggers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#808080;verticalAlign=top;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="100" width="2720" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="trg-sched" value="Scheduled Task&#xa;毎週 月 09:00 JST&#xa;→ Agent A をキック" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="80" y="140" width="360" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="trg-incident" value="Incident Trigger&#xa;Azure Monitor Alert / PagerDuty&#xa;→ Agent B を直接キック" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE7EA;strokeColor=#DD344C;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="480" y="140" width="360" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="trg-chat" value="Chat / /agent&#xa;運用担当のアドホック依頼&#xa;→ A または B を指名" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FA;strokeColor=#0078D4;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="880" y="140" width="360" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="trg-note" value="いずれのトリガーでも、最終的に A → (必要なら B) → C → D のチェーンに合流できる。&#xa;「配信先・成果物形式」だけを差し替えたい場合は C/D のみ変更する。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555555;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="140" width="1440" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="agentA" value="② Agent A — MetricsReporter（Workflow Executor）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F6E7;strokeColor=#107C10;verticalAlign=top;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="280" width="660" height="820" as="geometry"/>
                </mxCell>
                <mxCell id="agentA-yaml" value="name: metrics_reporter&#xa;tools:&#xa;  - execute_kusto_query&#xa;  - azure_cli / azure_monitor&#xa;handoff:&#xa;  - spike_investigator&#xa;  - report_renderer&#xa;  - notifier&#xa;enable_skills: true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#107C10;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="320" width="600" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="agentA-role" value="役割：オーケストレータ&#xa;&#xa;1. KB からしきい値 と KQL を参照&#xa;2. メトリクス値を収集&#xa;3. G / Y / R 判定&#xa;4. Y/R → Agent B に handoff&#xa;5. 結果を 1 つの JSON に統合&#xa;6. → Agent C に handoff（整形依頼）&#xa;7. → Agent D に handoff（配信依頼）&#xa;&#xa;書込み権限：なし" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F6E7;strokeColor=#107C10;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="510" width="600" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="agentA-kb" value="KB: architecture / metrics-catalog / thresholds / kusto-queries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C6E7C6;strokeColor=#107C10;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="770" width="600" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="agentA-mode" value="Run Mode: Autonomous（読取のみ）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="850" width="600" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="agentA-out" value="出力 JSON（次エージェント向け）&#xa;{ scope, metrics:[{name, value, status}], spikes:[...] }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#107C10;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="920" width="600" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="agentB" value="③ Agent B — SpikeInvestigator（Domain Expert）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE7EA;strokeColor=#DD344C;verticalAlign=top;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="720" y="280" width="660" height="820" as="geometry"/>
                </mxCell>
                <mxCell id="agentB-yaml" value="name: spike_investigator&#xa;tools:&#xa;  - execute_kusto_query&#xa;  - azure_cli&#xa;  - azure_monitor&#xa;handoff_description: |&#xa;  Yellow/Red 時に呼ばれ&#xa;  候補原因を信頼度付きで返す" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="750" y="320" width="600" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="agentB-role" value="役割：調査官&#xa;&#xa;1. 対象時刻 ± ウィンドウ決定&#xa;2. Activity Log / デプロイ履歴&#xa;3. Resource / Service Health&#xa;4. App Insights 例外・トレース&#xa;5. リソース飽和メトリクス&#xa;6. known-patterns と照合&#xa;7. 候補原因 JSON を返却&#xa;&#xa;書込み権限：なし（読取のみ）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE7EA;strokeColor=#DD344C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="750" y="510" width="600" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="agentB-kb" value="KB: known-patterns / dependency-map / investigation-playbook / owners" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAD7DA;strokeColor=#DD344C;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="750" y="770" width="600" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="agentB-mode" value="Run Mode: Review（PoC 初期）→ Autonomous（仮説の質を評価できてから）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="750" y="850" width="600" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="agentB-out" value="返却 JSON&#xa;{ spike, hypotheses:[{cause, confidence, evidence}],&#xa;  recommended_owner }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="750" y="920" width="600" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="agentC" value="④ Agent C — ReportRenderer（Task Specialist）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FA;strokeColor=#0078D4;verticalAlign=top;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1400" y="280" width="660" height="820" as="geometry"/>
                </mxCell>
                <mxCell id="agentC-yaml" value="name: report_renderer&#xa;tools:&#xa;  - ExecutePythonCode   # Utility&#xa;handoff_description: |&#xa;  JSON から PDF / PPTX / Markdown&#xa;  を生成し Blob に配置して URL 返す" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0078D4;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="320" width="600" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="agentC-role" value="役割：整形専門&#xa;&#xa;1. A（＋B）からの JSON を受領&#xa;2. Jinja2 テンプレートに差込み&#xa;3. WeasyPrint で PDF 生成&#xa;   /mnt/data/weekly-YYYYMMDD.pdf&#xa;4. Azure SDK で Blob upload&#xa;   （13 週保持ポリシ）&#xa;5. ダウンロード URL を返却&#xa;&#xa;書込み：Blob のみ（テンプレ領域）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FA;strokeColor=#0078D4;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="510" width="600" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="agentC-kb" value="KB: report-template.md（PDF レイアウト仕様） / style-guide.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFE4F5;strokeColor=#0078D4;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="770" width="600" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="agentC-mode" value="Run Mode: Review（PoC 初期）→ Autonomous（レポート形式が安定してから）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="850" width="600" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="agentC-out" value="返却 JSON&#xa;{ pdf_url, summary_markdown, severity, red_count }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0078D4;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="920" width="600" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="agentD" value="⑤ Agent D — Notifier（Task Specialist）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0FA;strokeColor=#5E5EC8;verticalAlign=top;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="2080" y="280" width="660" height="820" as="geometry"/>
                </mxCell>
                <mxCell id="agentD-yaml" value="name: notifier&#xa;tools:&#xa;  - send_notifications     # Teams/Outlook&#xa;  - servicenow_connector&#xa;  - azure_devops_connector&#xa;handoff_description: |&#xa;  成果物 URL + サマリを&#xa;  適切なチャネル/担当へ配信" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5E5EC8;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="2110" y="320" width="600" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="agentD-role" value="役割：配信専門&#xa;&#xa;1. C から URL + 要約を受領&#xa;2. severity に応じて配信先決定&#xa;   - Green: Teams 要約のみ&#xa;   - Yellow: Teams + メール&#xa;   - Red: + @mention + 起票&#xa;3. owners.md から担当部署特定&#xa;4. ServiceNow / ADO 起票（Red）&#xa;5. 配信結果を返却&#xa;&#xa;書込み：Teams / メール / チケット" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0FA;strokeColor=#5E5EC8;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="2110" y="510" width="600" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="agentD-kb" value="KB: owners / notification-policy.md（配信先マトリクス）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCDCEF;strokeColor=#5E5EC8;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="2110" y="770" width="600" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="agentD-mode" value="Run Mode: Review 維持（起票・@mention 等の書込みは人の承認を推奨）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE7EA;strokeColor=#DD344C;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="2110" y="850" width="600" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="agentD-out" value="最終アウトプット&#xa;Teams 通知 / メール / ServiceNow チケット / ADO Work Item" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5E5EC8;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="2110" y="920" width="600" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="arr-AB" value="handoff (Y/R 時)" style="endArrow=classic;html=1;strokeColor=#107C10;strokeWidth=3;fontSize=11;fontStyle=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="700" y="620" as="sourcePoint"/>
                        <mxPoint x="720" y="620" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-BA" value="return: 仮説 JSON" style="endArrow=classic;html=1;strokeColor=#DD344C;strokeWidth=2;dashed=1;fontSize=11;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="720" y="680" as="sourcePoint"/>
                        <mxPoint x="700" y="680" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-AC" value="handoff: 統合 JSON" style="endArrow=classic;html=1;strokeColor=#0078D4;strokeWidth=3;fontSize=11;fontStyle=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="700" y="1000" as="sourcePoint"/>
                        <mxPoint x="1400" y="620" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-CD" value="handoff: pdf_url + summary" style="endArrow=classic;html=1;strokeColor=#5E5EC8;strokeWidth=3;fontSize=11;fontStyle=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="2060" y="620" as="sourcePoint"/>
                        <mxPoint x="2080" y="620" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-sched" value="fire" style="endArrow=classic;html=1;strokeColor=#D97706;strokeWidth=2;fontSize=11;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="260" y="220" as="sourcePoint"/>
                        <mxPoint x="370" y="280" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-incident" value="fire" style="endArrow=classic;html=1;strokeColor=#DD344C;strokeWidth=2;fontSize=11;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="660" y="220" as="sourcePoint"/>
                        <mxPoint x="1050" y="280" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="bp" value="📌 責務分離のベストプラクティス&#xa;&#xa;▶ 書込み権限は D のみに集約 → A/B/C は Autonomous でも安全に稼働可能&#xa;▶ ハンドオフ間の受渡しは JSON に統一（履歴全量を引きずらない → コンテキスト肥大化を回避）&#xa;▶ C (Renderer) は週次以外にも再利用可：月次レポート、アドホック調査報告、障害ポストモーテム&#xa;▶ D (Notifier) の配信マトリクス（severity × channel × owner）を notification-policy.md に集約し変更容易に&#xa;▶ PoC 初期は D を Review、安定化後に Autonomous へ段階的に移行&#xa;▶ 失敗局所化：C 失敗でも B の仮説は記憶に残る、D 失敗でも PDF は Blob に残る" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;align=left;verticalAlign=top;fontSize=12;fontStyle=1;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1140" width="2720" height="260" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>