<mxfile host="65bd71144e">
    <diagram id="update-review-chain" name="Azure Update Review Chain">
        <mxGraphModel dx="649" dy="616" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="Azure Update 照合チェーン — 現状構成 × リリース情報" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="2720" height="36" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="E: 現状取得 + 照合 → F: (1) 一覧取得 → (2) 候補のみ詳細 URL 取得 → E が統合 → 既存 C (整形) → 既存 D (配信)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=13;fontStyle=2;fontColor=#555555;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="2720" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="trg-box" value="① Trigger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#808080;verticalAlign=top;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="100" width="2720" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="trg-sched" value="Scheduled Task&#xa;毎週 火 09:00 JST&#xa;→ Agent E をキック" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="80" y="140" width="360" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="trg-chat" value="Chat / /agent&#xa;リリース情報 URL を渡して&#xa;アドホック照合依頼も可" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FA;strokeColor=#0078D4;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="480" y="140" width="360" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="trg-note" value="月次レポートや棚卸し時にも同じチェーンを再利用可能。&#xa;既存の週次メトリクス チェーンとは Scheduled Task / 責務を分離。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#555555;" parent="1" vertex="1">
                    <mxGeometry x="880" y="140" width="1840" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="agentE" value="② Agent E — UpdateScanner（Orchestrator + 照合）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F6E7;strokeColor=#107C10;verticalAlign=top;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="280" width="900" height="820" as="geometry"/>
                </mxCell>
                <mxCell id="agentE-yaml" value="name: update_scanner&#xa;tools:&#xa;  - azure_cli         # ARG query&#xa;  - azure_monitor&#xa;handoff:&#xa;  - update_fetcher    # F&#xa;  - report_renderer   # C（再利用）&#xa;  - notifier          # D（再利用）&#xa;enable_skills: true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#107C10;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="320" width="840" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="agentE-role" value="役割：照合オーケストレータ&#xa;&#xa;1. Azure Resource Graph で現状構成を取得&#xa;   (SKU / version / region / extensions / policy)&#xa;2. Agent F に handoff (mode=list) → Update 一覧を取得&#xa;3. 一次スクリーニング：service-scope × tag で候補を抽出&#xa;4. 候補 URL のみ Agent F に handoff (mode=detail)&#xa;   → 詳細 Markdown を取得（全件詳細は取らない）&#xa;5. 詳細本文と「現状構成」を突合&#xa;   - Retirement/Breaking → Red&#xa;   - Feature/GA → Yellow（検討候補）&#xa;   - 無影響 → Green&#xa;6. リスク / コスト削減 / 効率化コメント生成&#xa;7. 統合 JSON を作成し Agent C にハンドオフ&#xa;&#xa;書込み権限：なし（読取のみ）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7F6E7;strokeColor=#107C10;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="520" width="840" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="agentE-kb" value="KB (Agent E)：guardrails.md / cost-baseline.md / architecture.md（設計意図のみ）&#xa;※ 現状のリソースは KB に入れない（ARG で都度取得）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C6E7C6;strokeColor=#107C10;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="820" width="840" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="agentE-mode" value="Run Mode: Review（PoC 初期）→ Autonomous（照合精度が確認できてから）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="70" y="910" width="840" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="agentE-out" value="出力 JSON&#xa;{ scope, resources:[{id,type,sku,ver}],&#xa;  matches:[{update_id, affected:[...], severity,&#xa;            risk, cost_hint, efficiency_hint}] }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#107C10;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="980" width="840" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="agentF" value="③ Agent F — UpdateFetcher（外部情報取得）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE7EA;strokeColor=#DD344C;verticalAlign=top;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="960" y="280" width="900" height="820" as="geometry"/>
                </mxCell>
                <mxCell id="agentF-yaml" value="name: update_fetcher&#xa;tools:&#xa;  - ExecutePythonCode   # Utility&#xa;    # search-azure-updates.py  (1 段目)&#xa;    # fetch-url.py             (2 段目)&#xa;handoff_description: |&#xa;  mode=list   : API 一覧を JSON で返す&#xa;  mode=detail : URL 群を Markdown で返す&#xa;enable_skills: true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="990" y="320" width="840" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="agentF-role" value="役割：Azure Update 取得の専門家（2 段階フェッチ）&#xa;&#xa;【1 段目 - mode=list】search-azure-updates.py&#xa;  1. Release Communications API をコール&#xa;     https://www.microsoft.com/releasecommunications&#xa;     /api/v2/azure  （認証不要）&#xa;  2. 過去 N 日 + $filter (retirement 等) で絞込&#xa;  3. タグ付け: RETIREMENT / BREAKING /&#xa;             GA / PREVIEW / FEATURE&#xa;  4. 一覧 JSON (title, url, date, tags) を E に返却&#xa;&#xa;【2 段目 - mode=detail】fetch-url.py&#xa;  5. E が絞った候補 URL 群のみ受領&#xa;  6. Selenium (headless) で JS レンダリング&#xa;  7. markdownify で本文 Markdown 化&#xa;  8. 詳細 Markdown を E に返却&#xa;&#xa;書込み権限：なし（外部 HTTPS 読取のみ）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDE7EA;strokeColor=#DD344C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="990" y="520" width="840" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="agentF-kb" value="KB (Agent F)：service-scope.md / api-notes.md (クエリ例)&#xa;fetch-notes.md（Selenium 待機条件・除去タグ・レート制御）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAD7DA;strokeColor=#DD344C;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="990" y="820" width="840" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="agentF-mode" value="Run Mode: Review（PoC 初期）→ Autonomous（取得範囲の妥当性が確認できてから）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#D97706;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="990" y="910" width="840" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="agentF-out" value="返却 JSON&#xa;list   : { updates:[{id,title,services,type,published_at,url,summary}] }&#xa;detail : { pages:[{url, markdown, fetched_at}] }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DD344C;align=left;verticalAlign=top;fontSize=11;fontFamily=Consolas;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="990" y="980" width="840" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="ext" value="④ 外部ソース（F が直接取得）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0FA;strokeColor=#5E5EC8;verticalAlign=top;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1880" y="280" width="880" height="500" as="geometry"/>
                </mxCell>
                <mxCell id="ext-api" value="🌐 1 段目：Release Communications API&#xa;&#xa;https://www.microsoft.com/releasecommunications&#xa;/api/v2/azure&#xa;&#xa;・認証不要 / OData 風 $filter&#xa;・返却は一覧（title・tags・公開日・URL）&#xa;・本文詳細は別 URL にある → 2 段目が必須" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5E5EC8;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1910" y="320" width="820" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="ext-detail" value="🌐 2 段目：Azure Updates 個別記事ページ（HTML）&#xa;&#xa;例) https://azure.microsoft.com/en-us/updates/xxxxx&#xa;・JS レンダリング必要 → Selenium headless&#xa;・markdownify で Markdown 化 → LLM に渡せる形へ&#xa;・E が候補に絞った URL のみ取得（全件取らない）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5E5EC8;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1910" y="470" width="820" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="ext-arg" value="🗂 Azure Resource Graph（E が直接取得）&#xa;&#xa;az graph query -q &quot;Resources | project id,type,sku,properties&quot;&#xa;・ARM リソース状態の真実&#xa;・KB に現状を書かなくてよい根拠" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#107C10;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1910" y="620" width="820" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="downstream" value="⑤ Downstream（既存チェーンを再利用）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0FA;strokeColor=#5E5EC8;verticalAlign=top;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1880" y="800" width="880" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="agentC-ref" value="[C] ReportRenderer（再利用）&#xa;&#xa;・KB 追加：update-review-template.md&#xa;・PDF 構成&#xa;  1. エグゼクティブサマリ&#xa;  2. 影響ありリソース 一覧&#xa;  3. update 詳細 × 推奨アクション&#xa;  4. コスト削減 / 効率化提案&#xa;  5. 参考 URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FA;strokeColor=#0078D4;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1910" y="840" width="400" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="agentD-ref" value="[D] Notifier（再利用）&#xa;&#xa;・Retirement/Breaking&#xa;  → Red: Teams @mention + 起票&#xa;・GA/Preview で推奨&#xa;  → Yellow: Teams + メール&#xa;・無影響&#xa;  → Green: サマリのみ&#xa;&#xa;Run Mode: Review 維持" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0FA;strokeColor=#5E5EC8;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="2330" y="840" width="400" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="arr-sched-E" value="fire" style="endArrow=classic;html=1;strokeColor=#D97706;strokeWidth=2;fontSize=11;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="260" y="220" as="sourcePoint"/>
                        <mxPoint x="400" y="280" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-EF1" value="handoff① mode=list (service-scope)" style="endArrow=classic;html=1;strokeColor=#107C10;strokeWidth=3;fontSize=11;fontStyle=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="940" y="580" as="sourcePoint"/>
                        <mxPoint x="960" y="580" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-FE1" value="return① updates 一覧 JSON" style="endArrow=classic;html=1;strokeColor=#DD344C;strokeWidth=2;dashed=1;fontSize=11;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="960" y="630" as="sourcePoint"/>
                        <mxPoint x="940" y="630" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-EF2" value="handoff② mode=detail (候補 URL 群)" style="endArrow=classic;html=1;strokeColor=#107C10;strokeWidth=3;fontSize=11;fontStyle=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="940" y="690" as="sourcePoint"/>
                        <mxPoint x="960" y="690" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-FE2" value="return② 詳細 Markdown" style="endArrow=classic;html=1;strokeColor=#DD344C;strokeWidth=2;dashed=1;fontSize=11;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="960" y="740" as="sourcePoint"/>
                        <mxPoint x="940" y="740" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-F-api" value="HTTPS" style="endArrow=classic;html=1;strokeColor=#5E5EC8;strokeWidth=2;fontSize=11;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1860" y="420" as="sourcePoint"/>
                        <mxPoint x="1910" y="420" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-E-arg" value="ARG query" style="endArrow=classic;html=1;strokeColor=#107C10;strokeWidth=2;fontSize=11;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="940" y="580" as="sourcePoint"/>
                        <mxPoint x="1910" y="590" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-E-C" value="handoff: 統合 JSON" style="endArrow=classic;html=1;strokeColor=#0078D4;strokeWidth=3;fontSize=11;fontStyle=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="930" y="1030" as="sourcePoint"/>
                        <mxPoint x="1910" y="900" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="arr-C-D" value="handoff: pdf_url" style="endArrow=classic;html=1;strokeColor=#5E5EC8;strokeWidth=3;fontSize=11;fontStyle=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="2310" y="910" as="sourcePoint"/>
                        <mxPoint x="2330" y="910" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="bp" value="📌 設計ポイント&#xa;&#xa;▶ 現状の「動的な」リソース情報は KB に入れず、Azure Resource Graph で都度取得（陳腐化回避）&#xa;▶ KB には「静的な」設計意図・ガードレール・サービスカテゴリ一覧のみを置く（guardrails / cost-baseline / service-scope / architecture）&#xa;▶ 外部 API 取得は Agent F に分離。Azure Update 以外（Service Health / Advisor / Marketplace）への拡張が容易&#xa;▶ 既存の C (ReportRenderer) / D (Notifier) を再利用。新規実装は E / F のみ&#xa;▶ Retirement / Breaking の検出は自動化し、チケット起票は Review で人が確認してから発火&#xa;▶ 照合ロジックの妥当性（誤検知率 / 取りこぼし率）を PoC 評価指標に組み込む → アジェンダ 3 に接続" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;align=left;verticalAlign=top;fontSize=12;fontStyle=1;spacingLeft=12;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1140" width="2720" height="260" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>