<mxfile host="app.diagrams.net" agent="copilot">
  <diagram id="architecture" name="SRE Agent Architecture">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Azure SRE Agent — Architecture Overview" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== LAYER 1: External Alert Sources ===== -->
        <mxCell id="ext-group" value="Alert Sources" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;dashed=0;verticalAlign=top;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="700" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="azmon" value="Azure Monitor&#xa;Alerts" style="shape=mxgraph.azure.azure_monitor;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="ext-group">
          <mxGeometry x="30" y="40" width="60" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="pagerduty" value="PagerDuty" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="ext-group">
          <mxGeometry x="160" y="50" width="100" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="servicenow" value="ServiceNow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="ext-group">
          <mxGeometry x="300" y="50" width="100" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="grafana" value="Managed&#xa;Grafana" style="shape=mxgraph.azure.grafana;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="ext-group">
          <mxGeometry x="460" y="40" width="60" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="datadog" value="Datadog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="ext-group">
          <mxGeometry x="580" y="50" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== LAYER 2: SRE Agent Core ===== -->
        <mxCell id="agent-group" value="Azure SRE Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FA;strokeColor=#0078D4;dashed=0;verticalAlign=top;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="100" y="280" width="700" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="incident-mgmt" value="Incident&#xa;Management" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;fontStyle=1;" vertex="1" parent="agent-group">
          <mxGeometry x="30" y="50" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="response-plan" value="Response Plans&#xa;(default: Autonomous)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="agent-group">
          <mxGeometry x="30" y="120" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="scheduled-task" value="Scheduled Tasks&#xa;(default: Autonomous)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="agent-group">
          <mxGeometry x="30" y="190" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="chat" value="Chat Interface&#xa;(Review mode)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="agent-group">
          <mxGeometry x="200" y="50" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="memory" value="Memory&#xa;System" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="agent-group">
          <mxGeometry x="200" y="120" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="extensions" value="Extensions&#xa;(Subagents)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="agent-group">
          <mxGeometry x="200" y="190" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Access Control Layers Box -->
        <mxCell id="acl-group" value="Access Control (3 Layers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;dashed=1;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="agent-group">
          <mxGeometry x="380" y="40" width="290" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="layer1" value="Layer 1: User Roles&#xa;Admin / Standard / Reader" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" vertex="1" parent="acl-group">
          <mxGeometry x="20" y="30" width="250" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="layer2" value="Layer 2: Run Modes&#xa;Review / Autonomous" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" vertex="1" parent="acl-group">
          <mxGeometry x="20" y="90" width="250" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="layer3" value="Layer 3: Agent Permissions&#xa;MI RBAC + OBO Fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" vertex="1" parent="acl-group">
          <mxGeometry x="20" y="150" width="250" height="45" as="geometry"/>
        </mxCell>

        <!-- ===== LAYER 3: Identity ===== -->
        <mxCell id="identity-group" value="Identity &amp; Permissions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;dashed=0;verticalAlign=top;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="900" y="280" width="280" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="entra" value="Entra ID" style="shape=mxgraph.azure.active_directory;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="identity-group">
          <mxGeometry x="30" y="50" width="60" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="mi" value="Managed&#xa;Identity" style="shape=mxgraph.azure.managed_identities;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="identity-group">
          <mxGeometry x="130" y="50" width="60" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="obo" value="OBO Flow&#xa;(temporary elevation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" vertex="1" parent="identity-group">
          <mxGeometry x="40" y="140" width="180" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== LAYER 4: Managed Resources ===== -->
        <mxCell id="res-group" value="Managed Resource Groups" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FA;strokeColor=#0078D4;dashed=0;verticalAlign=top;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="100" y="640" width="700" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="appservice" value="App&#xa;Service" style="shape=mxgraph.azure.app_service;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="res-group">
          <mxGeometry x="30" y="50" width="55" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="aks" value="AKS" style="shape=mxgraph.azure.kubernetes;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="res-group">
          <mxGeometry x="120" y="50" width="55" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="vm" value="VM" style="shape=mxgraph.azure.virtual_machine;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="res-group">
          <mxGeometry x="210" y="50" width="55" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="cosmosdb" value="Cosmos DB" style="shape=mxgraph.azure.cosmos_db;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="res-group">
          <mxGeometry x="300" y="50" width="55" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="loganalytics" value="Log&#xa;Analytics" style="shape=mxgraph.azure.log_analytics;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="res-group">
          <mxGeometry x="390" y="50" width="55" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="storage" value="Storage" style="shape=mxgraph.azure.storage;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="res-group">
          <mxGeometry x="480" y="50" width="55" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="sql" value="SQL DB" style="shape=mxgraph.azure.sql_database;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="res-group">
          <mxGeometry x="570" y="50" width="55" height="65" as="geometry"/>
        </mxCell>

        <!-- ===== LAYER 5: Users ===== -->
        <mxCell id="user-admin" value="SRE Agent&#xa;Administrator" style="shape=mxgraph.azure.user;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="930" y="100" width="50" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="user-standard" value="Standard&#xa;User" style="shape=mxgraph.azure.user;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1030" y="100" width="50" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="user-reader" value="Reader" style="shape=mxgraph.azure.user;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1130" y="100" width="50" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== CONNECTIONS ===== -->
        <!-- Alert sources → Incident Management -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0066CC;strokeWidth=2;" edge="1" parent="1" source="azmon" target="incident-mgmt">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e1l" value="Alerts" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="e1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0066CC;strokeWidth=1;dashed=1;" edge="1" parent="1" source="pagerduty" target="incident-mgmt">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0066CC;strokeWidth=1;dashed=1;" edge="1" parent="1" source="servicenow" target="incident-mgmt">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Incident → Response Plan -->
        <mxCell id="e4" style="edgeStyle=curved;curved=1;strokeColor=#ED7100;strokeWidth=2;" edge="1" parent="1" source="incident-mgmt" target="response-plan">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4l" value="triggers" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="e4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Users → Chat (via Layer 1) -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DD344C;strokeWidth=2;" edge="1" parent="1" source="user-admin" target="chat">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5l" value="Layer 1: RBAC" style="edgeLabel;html=1;fontSize=10;fontColor=#DD344C;" vertex="1" connectable="0" parent="e5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DD344C;strokeWidth=1;dashed=1;" edge="1" parent="1" source="user-standard" target="chat">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Agent → Managed Resources (via Layer 3) -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C925D1;strokeWidth=2;" edge="1" parent="1" source="agent-group" target="res-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7l" value="Layer 3: MI RBAC&#xa;+ OBO" style="edgeLabel;html=1;fontSize=10;fontColor=#C925D1;" vertex="1" connectable="0" parent="e7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Identity → Agent -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DD344C;strokeWidth=2;" edge="1" parent="1" source="identity-group" target="agent-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e8l" value="identity" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="e8">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Extensions note -->
        <mxCell id="ext-note" value="Custom subagents can be&#xa;registered via Extensions&#xa;(code-first, Foundry-hosted)" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#666666;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="340" y="500" width="200" height="50" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ===== Network Architecture: Hub-VNet PoC ===== -->
  <diagram id="network-architecture" name="Network Architecture">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== Azure JapanEast Region ===== -->
        <mxCell id="region-japaneast" value="Azure JapanEast" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FA;strokeColor=#0078D4;dashed=0;verticalAlign=top;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="300" y="80" width="1760" height="760" as="geometry"/>
