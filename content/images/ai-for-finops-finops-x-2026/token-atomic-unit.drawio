        <mxCell id="title" value="Token Economics ①　トークンは AI の最小単位（atomic unit）" style="text;html=1;fontSize=26;fontStyle=1;align=center;verticalAlign=middle;fontFamily=Yu Gothic UI;" vertex="1" parent="1">
          <mxGeometry x="260" y="18" width="1000" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="入力・推論・出力のすべてがトークンとして消費される。AI 支出を測る&quot;原価単位&quot;。" style="text;html=1;fontSize=15;align=center;fontColor=#555555;fontFamily=Yu Gothic UI;" vertex="1" parent="1">
          <mxGeometry x="260" y="62" width="1000" height="24" as="geometry" />
        </mxCell>
        <mxCell id="inbox" value="入力トークン" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#0078D4;fontStyle=1;fontSize=16;align=center;fontFamily=Yu Gothic UI;" vertex="1" parent="1">
          <mxGeometry x="90" y="110" width="380" height="52" as="geometry" />
        </mxCell>
        <mxCell id="modelbox" value="モデル / エージェント" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E5;strokeColor=#ED7100;fontStyle=1;fontSize=16;align=center;fontFamily=Yu Gothic UI;" vertex="1" parent="1">
          <mxGeometry x="570" y="110" width="380" height="52" as="geometry" />
        </mxCell>
        <mxCell id="outbox" value="出力 / 成果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontStyle=1;fontSize=16;align=center;fontFamily=Yu Gothic UI;" vertex="1" parent="1">
          <mxGeometry x="1050" y="110" width="380" height="52" as="geometry" />
        </mxCell>
        <mxCell id="indet" value="・プロンプト / システム指示&#10;・会話履歴&#10;・RAG 文書&#10;・ツール定義" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0078D4;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=14;fontFamily=Yu Gothic UI;" vertex="1" parent="1">
          <mxGeometry x="90" y="172" width="380" height="130" as="geometry" />
        </mxCell>
        <mxCell id="modeldet" value="・推論 / reasoning&#10;・ツール呼び出し&#10;・検証&#10;・再試行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#ED7100;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=14;fontFamily=Yu Gothic UI;" vertex="1" parent="1">
          <mxGeometry x="570" y="172" width="380" height="130" as="geometry" />
        </mxCell>
        <mxCell id="outdet" value="・回答 / コード / 要約&#10;・意思決定&#10;・業務アクション" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=14;fontFamily=Yu Gothic UI;" vertex="1" parent="1">
          <mxGeometry x="1050" y="172" width="380" height="130" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="推論" style="endArrow=block;html=1;strokeColor=#666666;strokeWidth=2;fontSize=13;fontFamily=Yu Gothic UI;" edge="1" parent="1" source="inbox" target="modelbox">
          <mxGeometry relative="1" as="geometry" />
